# Serper Dev API Key (required for search functionality)
SERPER_API_KEY=your-api-key

# LinkedIn API Credentials (optional, for actual publishing)
LINKEDIN_CLIENT_ID=your_linkedin_client_id_here
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret_here
LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token_here

# Application Settings
DEBUG=true
LOG_LEVEL=INFO
MAX_WORKERS=4

# Production API Security
# Define a strong API Key for secure authentication
API_KEY=your_secure_api_key_here
# Comma-separated allowed CORS origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8010

# Database Settings
DATABASE_PATH=storage/db/workflows.db

# LLM Configuration (For CrewAI to consume, e.g., local LM Studio, OpenAI, or Groq)
LLM_MODEL=openai/zai-org/glm-4.6v-flash
LLM_BASE_URL=http://localhost:1234/v1
LLM_API_KEY=lm-studio
LLM_TIMEOUT=120
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.7